// Second Largest Element


class Main {
    public static void main(String[] args) {
        int a[]={-4,4,3,8,0};
        int max=Integer.MIN_VALUE;
        int ans=Integer.MIN_VALUE;
        for(int i=0;i<a.length;i++)
        {
            if(a[i]>max)
            {   ans=max;
                max=a[i];
                
            }
            else if(max>a[i]&&a[i]>ans)
            {
                ans=a[i];
            }
        }
        System.out.println(ans+""+max);
    }
}

